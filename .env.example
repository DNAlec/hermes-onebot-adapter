# Hermes OneBot Plugin environment variables
# Add these to ~/.hermes/.env (or set in Docker)

# Required: adapter service WebSocket URL
ONEBOT_ADAPTER_URL=ws://127.0.0.1:18810/hermes

# Required: adapter service auth token (shown in adapter WebUI)
ONEBOT_ADAPTER_TOKEN=

# Optional: cron / notification delivery target chat_id
# Private chat: QQ number, Group: group:<group_id>
ONEBOT_HOME_CHANNEL=